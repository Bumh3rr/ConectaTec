<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/db_background"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="100dp">

            <!-- ══ A. HEADER ═════════════════════════════════════════ -->
            <!-- id preserved for animation in animarEntrada() -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardBienvenidaDocente"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/db_surface"
                app:cardCornerRadius="0dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="48dp"
                    android:paddingBottom="16dp"
                    android:paddingHorizontal="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">

                        <!-- Logo TC chip -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TC"
                            android:textColor="@color/white"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.05"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp"
                            android:background="@drawable/bg_chip_db_blue"
                            android:layout_marginEnd="12dp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Dashboard Docente"
                                android:textColor="@color/db_text_primary"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Hola, Prof. Carlos Bautista"
                                android:textColor="@color/db_text_muted"
                                android:textSize="12sp"
                                android:layout_marginTop="1dp" />

                        </LinearLayout>

                        <!-- Avatar docente -->
                        <FrameLayout
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_chip_docente">
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:text="CB"
                                android:textColor="@color/white"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </FrameLayout>

                    </LinearLayout>

                    <!-- Online indicator -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <View
                            android:layout_width="7dp"
                            android:layout_height="7dp"
                            android:background="@color/db_green"
                            android:layout_marginEnd="5dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="En línea"
                            android:textColor="@color/db_green"
                            android:textSize="11sp" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Border -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/db_border" />

            <!-- ══ B. KPI GRID ════════════════════════════════════════ -->
            <!-- id preserved for animation -->
            <LinearLayout
                android:id="@+id/layoutKpisDocente"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="12dp"
                android:paddingTop="16dp"
                android:paddingBottom="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MIS MÉTRICAS"
                    android:textColor="@color/db_text_muted"
                    android:textSize="9sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="10dp" />

                <!-- Fila 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardGruposActivosDocente"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:clickable="true"
                        android:focusable="true"
                        style="@style/KpiCard">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Mis Grupos"
                                android:textColor="@color/db_text_muted"
                                android:textSize="9sp"
                                android:textAllCaps="true"
                                android:letterSpacing="0.04"
                                android:layout_marginBottom="6dp" />

                            <TextView
                                android:id="@+id/tvTotalGruposDashboardDocente"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="3"
                                android:textColor="@color/db_green"
                                android:textSize="26sp"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Grupos activos"
                                android:textColor="@color/db_text_muted"
                                android:textSize="9sp"
                                android:layout_marginTop="4dp" />

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardAlumnosTotales"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:clickable="true"
                        android:focusable="true"
                        style="@style/KpiCard">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Alumnos"
                                android:textColor="@color/db_text_muted"
                                android:textSize="9sp"
                                android:textAllCaps="true"
                                android:letterSpacing="0.04"
                                android:layout_marginBottom="6dp" />

                            <TextView
                                android:id="@+id/tvTotalAlumnos"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="47"
                                android:textColor="@color/db_blue"
                                android:textSize="26sp"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Totales"
                                android:textColor="@color/db_text_muted"
                                android:textSize="9sp"
                                android:layout_marginTop="4dp" />

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <!-- Fila 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        style="@style/KpiCard">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tareas"
                                android:textColor="@color/db_text_muted"
                                android:textSize="9sp"
                                android:textAllCaps="true"
                                android:letterSpacing="0.04"
                                android:layout_marginBottom="6dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="8"
                                android:textColor="@color/db_purple"
                                android:textSize="26sp"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Publicadas"
                                android:textColor="@color/db_text_muted"
                                android:textSize="9sp"
                                android:layout_marginTop="4dp" />

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        style="@style/KpiCard">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Pendientes"
                                android:textColor="@color/db_text_muted"
                                android:textSize="9sp"
                                android:textAllCaps="true"
                                android:letterSpacing="0.04"
                                android:layout_marginBottom="6dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="5"
                                android:textColor="@color/db_red"
                                android:textSize="26sp"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Por calificar"
                                android:textColor="@color/db_text_muted"
                                android:textSize="9sp"
                                android:layout_marginTop="4dp" />

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

            </LinearLayout>

            <!-- ══ C. CHART: MIS TAREAS POR TIPO ═════════════════════ -->
            <!-- id preserved for animation: cardTareasRecientesDashboard -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardTareasRecientesDashboard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:layout_marginTop="12dp"
                style="@style/ChartCard">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="MIS TAREAS POR TIPO"
                            android:textColor="@color/db_text_muted"
                            android:textSize="9sp"
                            android:textAllCaps="true"
                            android:letterSpacing="0.08" />

                        <TextView
                            android:id="@+id/tvVerTodasTareasDashboard"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ver tareas"
                            android:textColor="@color/db_blue"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:clickable="true"
                            android:focusable="true" />

                    </LinearLayout>

                    <com.github.mikephil.charting.charts.PieChart
                        android:id="@+id/chartDonutTiposDocente"
                        android:layout_width="match_parent"
                        android:layout_height="200dp" />

                    <!-- Leyenda tipos docente -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="12dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="6dp">
                                <View android:layout_width="9dp" android:layout_height="9dp" android:background="@color/db_blue" android:layout_marginEnd="6dp"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tarea 4" android:textColor="@color/db_text_secondary" android:textSize="11sp"/>
                            </LinearLayout>

                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                                <View android:layout_width="9dp" android:layout_height="9dp" android:background="@color/db_purple" android:layout_marginEnd="6dp"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Examen 1" android:textColor="@color/db_text_secondary" android:textSize="11sp"/>
                            </LinearLayout>

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="6dp">
                                <View android:layout_width="9dp" android:layout_height="9dp" android:background="@color/db_green" android:layout_marginEnd="6dp"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Trabajo 2" android:textColor="@color/db_text_secondary" android:textSize="11sp"/>
                            </LinearLayout>

                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                                <View android:layout_width="9dp" android:layout_height="9dp" android:background="@color/db_orange" android:layout_marginEnd="6dp"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Proyecto 1" android:textColor="@color/db_text_secondary" android:textSize="11sp"/>
                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ══ D. CHART: CALIFICADAS VS SIN CALIFICAR ════════════ -->
            <!-- id preserved for animation: cardActividadHoyDashboard -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardActividadHoyDashboard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:layout_marginTop="12dp"
                style="@style/ChartCard">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CALIFICADAS VS SIN CALIFICAR"
                        android:textColor="@color/db_text_muted"
                        android:textSize="9sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="12dp" />

                    <com.github.mikephil.charting.charts.PieChart
                        android:id="@+id/chartDonutCalifDocente"
                        android:layout_width="match_parent"
                        android:layout_height="180dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="14dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center_horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="22"
                                android:textColor="@color/db_green"
                                android:textSize="26sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Calificadas"
                                android:textColor="@color/db_text_muted"
                                android:textSize="11sp"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="40dp"
                            android:background="@color/db_border"
                            android:layout_gravity="center_vertical" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center_horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="5"
                                android:textColor="@color/db_red"
                                android:textSize="26sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Sin calificar"
                                android:textColor="@color/db_text_muted"
                                android:textSize="11sp"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ══ E. BARRA: TOP ALUMNOS POR ENTREGAS ══════════════ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:layout_marginTop="12dp"
                style="@style/ChartCard">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TOP ALUMNOS — ENTREGAS"
                        android:textColor="@color/db_text_muted"
                        android:textSize="9sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="12dp" />

                    <com.github.mikephil.charting.charts.HorizontalBarChart
                        android:id="@+id/chartBarraAlumnos"
                        android:layout_width="match_parent"
                        android:layout_height="180dp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ══ F. BARRA: ACTIVIDAD POR GRUPO ════════════════════ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:layout_marginTop="12dp"
                style="@style/ChartCard">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ACTIVIDAD POR GRUPO — ESTA SEMANA"
                        android:textColor="@color/db_text_muted"
                        android:textSize="9sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="12dp" />

                    <com.github.mikephil.charting.charts.HorizontalBarChart
                        android:id="@+id/chartBarraGrupos"
                        android:layout_width="match_parent"
                        android:layout_height="140dp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ══ G. FEED: ÚLTIMAS ENTREGAS ═════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="12dp"
                android:paddingTop="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ÚLTIMAS ENTREGAS"
                    android:textColor="@color/db_text_muted"
                    android:textSize="9sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="10dp" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/ChartCard">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingVertical="8dp">

                        <!-- Entrega 1 -->
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:paddingHorizontal="14dp" android:paddingVertical="10dp">
                            <View android:layout_width="6dp" android:layout_height="6dp" android:background="@color/db_green" android:layout_marginEnd="12dp"/>
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="María López — Proyecto Final POO" android:textColor="@color/db_text_secondary" android:textSize="11sp"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Prog. Móvil 6A · hace 30 min" android:textColor="@color/db_text_muted" android:textSize="9sp" android:layout_marginTop="2dp"/>
                            </LinearLayout>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="95" android:textColor="@color/db_green" android:textSize="13sp" android:textStyle="bold"/>
                        </LinearLayout>

                        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/db_border" android:layout_marginHorizontal="14dp"/>

                        <!-- Entrega 2 -->
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:paddingHorizontal="14dp" android:paddingVertical="10dp">
                            <View android:layout_width="6dp" android:layout_height="6dp" android:background="@color/db_blue" android:layout_marginEnd="12dp"/>
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Jorge Martínez — Tarea 3 Normalización BD" android:textColor="@color/db_text_secondary" android:textSize="11sp"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Bases de Datos 4B · hace 1h" android:textColor="@color/db_text_muted" android:textSize="9sp" android:layout_marginTop="2dp"/>
                            </LinearLayout>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textColor="@color/db_text_muted" android:textSize="13sp"/>
                        </LinearLayout>

                        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/db_border" android:layout_marginHorizontal="14dp"/>

                        <!-- Entrega 3 -->
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:paddingHorizontal="14dp" android:paddingVertical="10dp">
                            <View android:layout_width="6dp" android:layout_height="6dp" android:background="@color/db_purple" android:layout_marginEnd="12dp"/>
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ana Ramírez — Tarea 5: Integrales" android:textColor="@color/db_text_secondary" android:textSize="11sp"/>

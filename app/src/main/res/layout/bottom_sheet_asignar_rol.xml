<?xml version="1.0" encoding="utf-8"?>
<!-- BottomSheet para asignar rol a un usuario -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/colorSurface"
    android:orientation="vertical"
    android:paddingBottom="32dp">

    <!-- Handle de arrastre -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="20dp"
        android:background="@color/colorBorder"
        android:alpha="0.6" />

    <!-- Título -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:paddingBottom="16dp"
        android:text="@string/title_asignar_rol"
        android:textColor="@color/colorOnSurface"
        android:textSize="20sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/colorDivider"
        android:layout_marginBottom="8dp" />

    <!-- Opción: PENDIENTE -->
    <LinearLayout
        android:id="@+id/opcionPendiente"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="24dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_rol_pendiente"
            android:textColor="@color/white"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:background="@drawable/bg_chip_pendiente" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:text="Pendiente"
            android:textColor="@color/colorOnSurface"
            android:textSize="15sp" />

        <RadioButton
            android:id="@+id/rbPendiente"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:clickable="false"
            android:focusable="false"
            android:buttonTint="@color/colorPrimary" />

    </LinearLayout>

    <!-- Opción: ADMINISTRADOR -->
    <LinearLayout
        android:id="@+id/opcionAdmin"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="24dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_administrador"
            android:textColor="@color/white"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:background="@drawable/bg_chip_admin" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:text="Administrador"
            android:textColor="@color/colorOnSurface"
            android:textSize="15sp" />

        <RadioButton
            android:id="@+id/rbAdmin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:clickable="false"
            android:focusable="false"
            android:buttonTint="@color/colorPrimary" />

    </LinearLayout>

    <!-- Opción: DOCENTE -->
    <LinearLayout
        android:id="@+id/opcionDocente"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="24dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_docente"
            android:textColor="@color/white"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:background="@drawable/bg_chip_docente" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:text="Docente"
            android:textColor="@color/colorOnSurface"
            android:textSize="15sp" />

        <RadioButton
            android:id="@+id/rbDocente"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:clickable="false"
            android:focusable="false"
            android:buttonTint="@color/colorPrimary" />

    </LinearLayout>

    <!-- Opción: ESTUDIANTE -->
    <LinearLayout
        android:id="@+id/opcionEstudiante"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="24dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_estudiante"
            android:textColor="@color/white"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:background="@drawable/bg_chip_estudiante" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:text="Estudiante"
            android:textColor="@color/colorOnSurface"
            android:textSize="15sp" />

        <RadioButton
            android:id="@+id/rbEstudiante"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:clickable="false"
            android:focusable="false"
            android:buttonTint="@color/colorPrimary" />

    </LinearLayout>

    <!-- Divider y botón confirmar -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/colorDivider"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="20dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnConfirmarRol"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginHorizontal="24dp"
        android:text="@string/btn_confirmar"
        android:textColor="@color/white"
        android:textSize="15sp"
        android:letterSpacing="0.05"
        android:stateListAnimator="@null"
        app:backgroundTint="@color/colorPrimary"
        app:cornerRadius="10dp" />

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorBackground">

    <!-- ══ STEP INDICATOR ════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="52dp"
        android:paddingHorizontal="28dp"
        android:paddingBottom="0dp"
        android:gravity="center_vertical">

        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="4dp"
            android:layout_weight="1"
            app:cardBackgroundColor="@color/colorPrimary"
            app:cardCornerRadius="2dp"
            app:cardElevation="0dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="4dp"
            android:layout_weight="1"
            android:layout_marginStart="5dp"
            app:cardBackgroundColor="@color/colorPrimary"
            app:cardCornerRadius="2dp"
            app:cardElevation="0dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="4dp"
            android:layout_weight="1"
            android:layout_marginStart="5dp"
            app:cardBackgroundColor="@color/colorDivider"
            app:cardCornerRadius="2dp"
            app:cardElevation="0dp" />

    </LinearLayout>

    <!-- ══ HEADER ════════════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="28dp"
        android:paddingTop="28dp"
        android:paddingBottom="0dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PASO 2 DE 3"
            android:textColor="@color/colorPrimary"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.15"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Foto de perfil"
            android:textColor="@color/colorOnSurface"
            android:textSize="26sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Coloca tu rostro dentro del marco. Tu foto será verificada por IA para confirmar que eres una persona real."
            android:textColor="@color/colorOnSurfaceVariant"
            android:textSize="13sp"
            android:lineSpacingExtra="3dp" />

    </LinearLayout>

    <!-- ══ SCANNER AREA ══════════════════════════════════════════ -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center">

        <!-- Fondo oscuro del área de escaneo -->
        <FrameLayout
            android:layout_width="268dp"
            android:layout_height="268dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_scan_area">

            <!-- Círculo de foto / placeholder -->
            <FrameLayout
                android:layout_width="192dp"
                android:layout_height="192dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_avatar_placeholder">

                <!-- Ícono placeholder (visible sin foto) -->
                <ImageView
                    android:id="@+id/ivFotoPlaceholder"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/ic_menu_camera"
                    android:contentDescription="@null"
                    android:scaleType="fitCenter"
                    app:tint="@color/colorOnSurfaceVariant" />

                <!-- Foto seleccionada (oculta hasta tener foto) -->
                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/ivFotoPreview"
                    android:layout_width="192dp"
                    android:layout_height="192dp"
                    android:layout_gravity="center"
                    android:visibility="gone"
                    app:civ_border_width="3dp"
                    app:civ_border_color="@color/colorPrimary" />

            </FrameLayout>

            <!-- Esquinas del marco escáner (overlay) -->
            <ImageView
                android:id="@+id/ivScanFrame"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_scan_frame"
                android:scaleType="fitXY"
                android:contentDescription="@null" />

            <!-- Línea de escaneo animada (oculta hasta presionar Continuar) -->
            <View
                android:id="@+id/viewScanLine"
                android:layout_width="192dp"
                android:layout_height="3dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_scan_line"
                android:visibility="gone" />

            <!-- Overlay semitransparente durante escaneo -->
            <FrameLayout
                android:id="@+id/overlayEscaneo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#55000000"
                android:visibility="gone"
                android:gravity="bottom|center_horizontal"
                android:paddingBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|center_horizontal"
                    android:text="Analizando..."
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:background="#661976D2"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp" />

            </FrameLayout>

        </FrameLayout>

    </FrameLayout>

    <!-- ══ ESTADO / HINT ═════════════════════════════════════════ -->
    <TextView
        android:id="@+id/tvEstadoFoto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Sin foto seleccionada"
        android:textColor="@color/colorOnSurfaceVariant"
        android:textSize="12sp"
        android:gravity="center"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="4dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Asegúrate de que tu rostro sea visible y esté bien iluminado"
        android:textColor="@color/colorOnSurfaceVariant"
        android:textSize="11sp"
        android:gravity="center"
        android:layout_marginBottom="24dp"
        android:paddingHorizontal="28dp" />

    <!-- ══ BOTONES ACCIÓN ═════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="28dp"
        android:layout_marginBottom="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTomarFoto"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="@string/btn_tomar_foto"
            android:textSize="13sp"
            android:textColor="@color/colorPrimary"
            app:strokeColor="@color/colorPrimary"
            app:cornerRadius="12dp"
            app:icon="@android:drawable/ic_menu_camera"
            app:iconTint="@color/colorPrimary"
            app:iconSize="18dp"
            app:iconGravity="textStart"
            android:stateListAnimator="@null" />

        <Space
            android:layout_width="12dp"
            android:layout_height="wrap_content" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGaleria"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="@string/btn_galeria"
            android:textSize="13sp"
            android:textColor="@color/colorPrimary"
            app:strokeColor="@color/colorPrimary"
            app:cornerRadius="12dp"
            app:icon="@android:drawable/ic_menu_gallery"
            app:iconTint="@color/colorPrimary"
            app:iconSize="18dp"
            app:iconGravity="textStart"
            android:stateListAnimator="@null" />

    </LinearLayout>

    <!-- ══ NOTA INFORMATIVA ═══════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/bg_card"
        android:padding="14dp"
        android:layout_marginHorizontal="28dp"
        android:layout_marginBottom="20dp"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_info"
            android:layout_marginEnd="10dp"
            android:contentDescription="@null"
            app:tint="@color/colorPrimary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Usa una foto clara de tu rostro. No se aceptan avatares, caricaturas ni imágenes sin rostro."
            android:textColor="@color/colorOnSurfaceVariant"
            android:textSize="12sp"
            android:lineSpacingExtra="2dp" />

    </LinearLayout>

    <!-- ══ BOTÓN CONTINUAR ════════════════════════════════════════ -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnContinuar"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginHorizontal="28dp"
        android:layout_marginBottom="28dp"
        android:text="Continuar"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:letterSpacing="0.05"
        android:enabled="false"
        android:alpha="0.5"
        app:backgroundTint="@color/colorPrimary"
        app:cornerRadius="12dp"
        android:stateListAnimator="@null" />

</LinearLayout>

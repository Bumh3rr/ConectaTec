<?xml version="1.0" encoding="utf-8"?>
<!-- Perfil del Administrador -->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="0dp"
        android:paddingBottom="40dp">

        <!-- ══ HEADER MARCA ══════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="48dp"
            android:paddingBottom="24dp">

            <!-- Línea decorativa izquierda -->
            <View
                android:layout_width="4dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_accent_bar"
                android:layout_marginEnd="14dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name"
                    android:textColor="@color/colorPrimary"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.18"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mi perfil"
                    android:textColor="@color/colorOnSurface"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Cuenta de Administrador"
                    android:textColor="@color/colorOnSurfaceVariant"
                    android:textSize="12sp"
                    android:letterSpacing="0.03" />

            </LinearLayout>

        </LinearLayout>

        <!-- Avatar + nombre + correo + chip ADMIN -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="28dp">

            <FrameLayout
                android:layout_width="96dp"
                android:layout_height="96dp">

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/ivAvatarPerfil"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:src="@drawable/bg_avatar_placeholder"
                    android:contentDescription="@string/cd_foto_perfil" />

                <TextView
                    android:id="@+id/tvInicialesPerfil"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="LR"
                    android:textColor="@color/white"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:visibility="visible" />

            </FrameLayout>

            <TextView
                android:id="@+id/tvNombrePerfil"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Luis Miguel Ramírez"
                android:textColor="@color/colorOnSurface"
                android:textSize="22sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:gravity="center" />

            <TextView
                android:id="@+id/tvCorreoPerfil"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="luis.ramirez@tec.mx"
                android:textColor="@color/colorOnSurfaceVariant"
                android:textSize="14sp"
                android:gravity="center" />

            <!-- Chip ADMINISTRADOR -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/label_administrador"
                android:textColor="@color/white"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:paddingHorizontal="14dp"
                android:paddingVertical="5dp"
                android:background="@drawable/bg_chip_admin" />

        </LinearLayout>

        <!-- Card: Información de cuenta -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="@color/colorSurface"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_info_cuenta"
                    android:textColor="@color/colorOnSurfaceVariant"
                    android:textSize="12sp"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="16dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/colorDivider"
                    android:layout_marginBottom="16dp" />

                <!-- Nombre -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Nombre"
                        android:textColor="@color/colorOnSurfaceVariant"
                        android:textSize="13sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Luis Miguel Ramírez"
                        android:textColor="@color/colorOnSurface"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- Correo -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Correo"
                        android:textColor="@color/colorOnSurfaceVariant"
                        android:textSize="13sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="luis.ramirez@tec.mx"
                        android:textColor="@color/colorOnSurface"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- Fecha de registro -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/label_fecha_registro"
                        android:textColor="@color/colorOnSurfaceVariant"
                        android:textSize="13sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="01/09/2024"
                        android:textColor="@color/colorOnSurface"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Espaciador -->
        <Space
            android:layout_width="match_parent"
            android:layout_height="8dp" />

        <!-- Botón cerrar sesión -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogoutAdmin"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/btn_cerrar_sesion"
            android:textSize="15sp"
            android:textColor="@color/colorError"
            android:letterSpacing="0.05"
            app:strokeColor="@color/colorError"
            app:cornerRadius="10dp"
            android:stateListAnimator="@null" />

    </LinearLayout>

</ScrollView>

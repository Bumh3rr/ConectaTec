<?xml version="1.0" encoding="utf-8"?>
<!-- Conversación del Docente — Plan 5 -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <!-- Header back -->
    <LinearLayout
        android:id="@+id/headerConversacion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="16dp"
        android:paddingTop="48dp"
        android:paddingBottom="12dp"
        android:background="@color/colorSurface"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBackConversacion"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:contentDescription="@string/cd_volver"
            android:src="@drawable/ic_arrow_left"
            app:tint="@color/colorOnSurface"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvNombreSalaConversacion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/colorOnSurface" />

            <TextView
                android:id="@+id/tvSubtituloSalaConversacion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/colorOnSurfaceVariant"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>

    <!-- RecyclerView de mensajes -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMensajesChat"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="8dp"
        android:paddingTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/headerConversacion"
        app:layout_constraintBottom_toTopOf="@id/barraInferiorChat" />

    <!-- Barra inferior fija -->
    <LinearLayout
        android:id="@+id/barraInferiorChat"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp"
        android:background="@color/colorSurface"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:id="@+id/btnAdjuntarChat"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:padding="6dp"
            android:src="@drawable/ic_paperclip"
            app:tint="@color/colorOnSurfaceVariant"
            android:contentDescription="@string/desc_btn_adjuntar"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true" />

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etMensajeChat"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginHorizontal="8dp"
            android:background="@drawable/bg_input"
            android:hint="@string/hint_mensaje_chat"
            android:inputType="textMultiLine|textCapSentences"
            android:maxLines="4"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp"
            android:textColor="@color/colorOnSurface"
            android:textColorHint="@color/colorOnSurfaceVariant"
            android:textSize="14sp" />

        <ImageView
            android:id="@+id/btnEnviarChat"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:padding="6dp"
            android:src="@drawable/ic_send"
            app:tint="@color/colorPrimary"
            android:contentDescription="@string/desc_btn_enviar"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>

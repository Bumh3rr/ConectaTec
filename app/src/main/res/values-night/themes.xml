<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.TecConnect" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryVariant">@color/colorPrimaryDark</item>
        <item name="colorOnPrimary">@color/colorOnPrimary</item>
        <item name="colorSurface">@color/colorSurface</item>
        <item name="colorSurfaceVariant">@color/colorSurfaceVariant</item>
        <item name="colorOnSurface">@color/colorOnSurface</item>
        <item name="colorOnSurfaceVariant">@color/colorOnSurfaceVariant</item>
        <item name="colorError">@color/colorError</item>
        <item name="android:colorBackground">@color/colorBackground</item>
        <item name="android:windowBackground">@color/colorBackground</item>
        <item name="android:statusBarColor">@color/colorBackground</item>
        <item name="android:navigationBarColor">@color/colorSurface</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="textInputStyle">@style/Widget.Material3.TextInputLayout.OutlinedBox</item>
    </style>

    <!-- Splash sin parpadeo blanco -->
    <style name="Theme.TecConnect.Splash" parent="Theme.TecConnect">
        <item name="android:windowBackground">@color/colorPrimary</item>
        <item name="android:statusBarColor">@color/colorPrimary</item>
    </style>

    <!-- Toolbar -->
    <style name="Widget.TecConnect.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">@color/colorSurface</item>
        <item name="titleTextColor">@color/colorOnSurface</item>
        <item name="subtitleTextColor">@color/colorOnSurfaceVariant</item>
    </style>

    <!-- Botón principal -->
    <style name="Widget.TecConnect.Button" parent="Widget.Material3.Button">
        <item name="android:backgroundTint">@color/colorPrimary</item>
        <item name="android:textColor">@color/colorOnPrimary</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <!-- Botón outlined -->
    <style name="Widget.TecConnect.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/colorPrimary</item>
        <item name="android:textColor">@color/colorPrimary</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <!-- Card -->
    <style name="Widget.TecConnect.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/colorSurface</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <!-- TextInputLayout -->
    <style name="Widget.TecConnect.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/colorSurfaceVariant</item>
        <item name="boxStrokeColor">@color/colorBorder</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="hintTextColor">@color/colorOnSurfaceVariant</item>
        <item name="android:textColorHint">@color/colorOnSurfaceVariant</item>
    </style>

    <!-- FAB -->
    <style name="Widget.TecConnect.FAB" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="backgroundTint">@color/colorPrimary</item>
        <item name="tint">@color/white</item>
    </style>

</resources>